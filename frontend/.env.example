# =============================================================================
# LinkUp Frontend – משתני סביבה (דוגמה)
# =============================================================================
# העתק לקובץ .env ומלא ערכים. אל תעלה .env ל-Git.
# מפתחות סודיים: מקור האמת הוא הבקאנד; הפרונט מקבל מפתחות דרך API (למשל Maps).
# =============================================================================

# כתובת ה-API של הבקאנד (ללא סלאש בסוף)
VITE_API_URL=http://localhost:8000/api/v1

# timeout לבקשות API (מילישניות). ברירת מחדל 30000 (30 שניות)
# VITE_API_TIMEOUT_MS=30000

# --- אופציונלי: מפתח Google Maps לתצוגת מפה ---
# ברירת מחדל: הפרונט מקבל את המפתח מהבקאנד (GET /api/v1/geo/maps-key).
# הגדר כאן רק אם אתה בונה ללא בקאנד או רוצה override. מקור האמת: backend/.env → GOOGLE_MAPS_API_KEY
# VITE_GOOGLE_MAPS_API_KEY=

# --- Google OAuth Sign-In ---
# מקור אמת: backend/docs/GOOGLE_OAUTH.md (אותו Client ID כמו ב-backend; ב-Console: origins + redirect URIs בלי כפילויות)
# VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
