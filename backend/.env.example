# =============================================================================
# LinkUp Backend – משתני סביבה (דוגמה)
# =============================================================================
# העתק לקובץ .env ומלא ערכים אמיתיים. אל תעלה .env ל-Git.
# מקור אמת: כל המפתחות והסודות מוגדרים כאן; הפרונט מקבל מפתחות נדרשים דרך API
# (למשל מפתח Google Maps – GET /api/v1/geo/maps-key).
# =============================================================================

# --- כללי ---
PROJECT_NAME=LinkUp
APP_NAME=linkup-backend
DEBUG=False

# --- אבטחה (חובה בפרודקשן) ---
# SECRET_KEY = מפתח לחתימת JWT. חייב להיות זהה ל-JWT_SECRET ב-chat-ws (.env) – אחרת אימות ב-WebSocket נשבר.
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- PostgreSQL / PostGIS ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=
POSTGRES_DB=linkup_app
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CHAT_DB=1

# --- RabbitMQ ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- Kafka ---

# --- פרונט וכתובות ---
FRONTEND_URL=https://linkup.co.il
API_PUBLIC_URL=

# --- Brevo (דוא"ל) ---
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=LinkUp

# --- Firebase ---
# Firebase credentials (paste full JSON as single line for production)
FIREBASE_CREDENTIALS_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=

# --- AWS / S3 ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
S3_BUCKET_NAME=

# --- EIA (מחירי דלק) ---
EIA_API_KEY=

# --- Google Maps (מקור אמת יחיד למפתח) ---
# משמש: Geocoding, Directions, Distance Matrix בבקאנד.
# הפרונט מקבל את המפתח אוטומטית דרך GET /api/v1/geo/maps-key (תצוגת מפה).
# אין צורך להגדיר מפתח נפרד בפרונט.
GOOGLE_MAPS_API_KEY=

# --- Google OAuth Sign-In ---
# מקור אמת: backend/docs/GOOGLE_OAUTH.md (אותו Client ID ב-frontend; ב-Console: origins + redirect URIs בלי כפילויות)
GOOGLE_CLIENT_ID=
